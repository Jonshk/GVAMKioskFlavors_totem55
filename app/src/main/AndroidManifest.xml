<?xml version="1.0" encoding="utf-8"?>

<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permite localizar las aplicaciones instaladas con lanzador -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <!-- Arranque automático -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Compatibilidad opcional con dispositivos USB -->
    <uses-feature
        android:name="android.hardware.usb.host"
        android:required="false" />

    <application
        android:allowBackup="false"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Material3.Light.NoActionBar">

        <!-- =====================================================
             LAUNCHER PRINCIPAL
             ===================================================== -->

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:resizeableActivity="false"
            android:screenOrientation="portrait">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

        </activity>

        <!-- =====================================================
             CONFIGURACIÃ“N
             ===================================================== -->

        <activity
            android:name=".ui.AppPickerActivity"
            android:exported="false" />

        <activity
            android:name=".ui.AppearanceActivity"
            android:exported="false" />

        <activity
            android:name=".ui.AdminUnlockActivity"
            android:exported="false" />

        <activity
            android:name=".ui.AboutActivity"
            android:exported="false" />

        <!--
        Actívala solamente cuando exista WifiActivity.kt:

        <activity
            android:name=".ui.WifiActivity"
            android:exported="false" />
        -->

        <!-- =====================================================
             SERVICIO DE ACCESIBILIDAD
             ===================================================== -->

        <service
            android:name=".system.KioskGuardService"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">

            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>

            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_kiosk_config" />

        </service>

        <!-- =====================================================
             ARRANQUE DEL LAUNCHER
             ===================================================== -->

        <receiver
            android:name=".system.BootReceiver"
            android:enabled="true"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>

        </receiver>

        <!-- =====================================================
             RECEPTOR USB OPCIONAL
             =====================================================

        <receiver
            android:name=".system.UsbKeyReceiver"
            android:enabled="true"
            android:exported="true">

            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
            </intent-filter>

            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/usb_device_filter" />

        </receiver>

        -->

    </application>

</manifest>
