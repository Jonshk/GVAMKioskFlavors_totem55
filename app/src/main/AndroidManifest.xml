<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.gvam.kioskportal">

    <!-- Permite consultar actividades lanzables para el selector -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <!-- Autoinicio tras reinicio (si usas BootReceiver) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- USB host opcional (teclado/pendrive “llavero”) -->
    <uses-feature
        android:name="android.hardware.usb.host"
        android:required="false" />

    <application
        android:allowBackup="false"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Material3.Light.NoActionBar">

        <!-- Launcher/Home: bloqueado en vertical -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:resizeableActivity="false"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Pantallas auxiliares -->
        <activity android:name=".ui.AdminUnlockActivity" android:exported="false" />
        <activity android:name=".ui.AboutActivity" android:exported="false" />
        <activity android:name=".ui.AppPickerActivity" android:exported="false" />
        <!-- (Si no usas WifiActivity, puedes eliminarla) -->
        <!-- <activity android:name=".ui.WifiActivity" android:exported="false" /> -->

        <!-- Accesibilidad: rebote + hotkeys globales -->
        <service
            android:name=".system.KioskGuardService"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_kiosk_config" />
        </service>

        <!-- Autoinicio al arrancar (opcional) -->
        <receiver
            android:name=".system.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- USB “llavero” (opcional) -->
        <!--
        <receiver
            android:name=".system.UsbKeyReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
            </intent-filter>
            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/usb_device_filter" />
        </receiver>
        -->
    </application>
</manifest>
